{
  "$description": "Design tokens — Школа нутрициологов «Ресурс». Light / Tiffany. Формат, близкий к W3C Design Tokens (значение в $value, тип в $type).",
  "color": {
    "primitive": {
      "teal-900":   { "$value": "#082B29", "$type": "color" },
      "teal-800":   { "$value": "#0C3B38", "$type": "color" },
      "teal-700":   { "$value": "#124E4A", "$type": "color" },
      "teal-ink":   { "$value": "#183633", "$type": "color" },
      "tiffany-700":{ "$value": "#0A968D", "$type": "color" },
      "tiffany-500":{ "$value": "#12B5AB", "$type": "color" },
      "tiffany-200":{ "$value": "#A6E6DF", "$type": "color" },
      "tiffany-050":{ "$value": "#E7F6F4", "$type": "color" },
      "paper":      { "$value": "#F7FBFA", "$type": "color" },
      "white":      { "$value": "#FFFFFF", "$type": "color" },
      "mist":       { "$value": "#EDF7F5", "$type": "color" },
      "on-deep":    { "$value": "#EAF6F4", "$type": "color" },
      "gray":       { "$value": "#94A9A6", "$type": "color" },
      "deep-contrast": { "$value": "#06322F", "$type": "color" }
    },
    "text": {
      "default":       { "$value": "{color.primitive.teal-ink}", "$type": "color" },
      "muted":         { "$value": "rgba(24,54,51,0.68)", "$type": "color" },
      "on-accent":     { "$value": "{color.primitive.deep-contrast}", "$type": "color" },
      "on-deep":       { "$value": "{color.primitive.on-deep}", "$type": "color" },
      "on-deep-muted": { "$value": "rgba(234,246,244,0.72)", "$type": "color" }
    },
    "surface": {
      "bg":  { "$value": "{color.primitive.paper}", "$type": "color" },
      "base":{ "$value": "{color.primitive.white}", "$type": "color" },
      "alt": { "$value": "{color.primitive.mist}", "$type": "color" }
    },
    "accent": {
      "default": { "$value": "{color.primitive.tiffany-500}", "$type": "color" },
      "strong":  { "$value": "{color.primitive.tiffany-700}", "$type": "color" },
      "soft":    { "$value": "{color.primitive.tiffany-200}", "$type": "color" },
      "wash":    { "$value": "{color.primitive.tiffany-050}", "$type": "color" }
    },
    "deep": {
      "default": { "$value": "{color.primitive.teal-800}", "$type": "color" },
      "alt":     { "$value": "{color.primitive.teal-700}", "$type": "color" },
      "darkest": { "$value": "{color.primitive.teal-900}", "$type": "color" },
      "line":    { "$value": "rgba(234,246,244,0.16)", "$type": "color" }
    },
    "border": {
      "default": { "$value": "rgba(24,54,51,0.12)", "$type": "color" },
      "strong":  { "$value": "rgba(24,54,51,0.24)", "$type": "color" }
    },
    "status": {
      "negative": { "$value": "{color.primitive.gray}", "$type": "color" }
    }
  },
  "font": {
    "family": {
      "display": { "$value": "Spectral, Georgia, serif", "$type": "fontFamily" },
      "body":    { "$value": "Golos Text, system-ui, sans-serif", "$type": "fontFamily" }
    },
    "weight": {
      "light":    { "$value": 300, "$type": "fontWeight" },
      "regular":  { "$value": 400, "$type": "fontWeight" },
      "medium":   { "$value": 500, "$type": "fontWeight" },
      "semibold": { "$value": 600, "$type": "fontWeight" },
      "bold":     { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "display-1": { "$value": "clamp(38px, 6.6vw, 72px)", "$type": "dimension" },
      "display-2": { "$value": "clamp(23px, 3.6vw, 40px)", "$type": "dimension" },
      "h2":        { "$value": "clamp(28px, 4.4vw, 46px)", "$type": "dimension" },
      "h3":        { "$value": "clamp(23px, 3.3vw, 33px)", "$type": "dimension" },
      "h4":        { "$value": "20px", "$type": "dimension" },
      "lead":      { "$value": "clamp(17px, 2vw, 20px)", "$type": "dimension" },
      "body":      { "$value": "17px", "$type": "dimension" },
      "small":     { "$value": "14.5px", "$type": "dimension" },
      "eyebrow":   { "$value": "12.5px", "$type": "dimension" }
    },
    "lineHeight": {
      "tight":  { "$value": 1.08, "$type": "number" },
      "snug":   { "$value": 1.25, "$type": "number" },
      "normal": { "$value": 1.6,  "$type": "number" }
    },
    "letterSpacing": {
      "eyebrow": { "$value": "0.18em",  "$type": "dimension" },
      "tight":   { "$value": "-0.01em", "$type": "dimension" }
    }
  },
  "space": {
    "2xs": { "$value": "4px",  "$type": "dimension" },
    "xs":  { "$value": "8px",  "$type": "dimension" },
    "sm":  { "$value": "12px", "$type": "dimension" },
    "md":  { "$value": "16px", "$type": "dimension" },
    "lg":  { "$value": "24px", "$type": "dimension" },
    "xl":  { "$value": "32px", "$type": "dimension" },
    "2xl": { "$value": "48px", "$type": "dimension" },
    "3xl": { "$value": "64px", "$type": "dimension" },
    "section-y": { "$value": "clamp(58px, 8vw, 112px)", "$type": "dimension" }
  },
  "layout": {
    "container-max":    { "$value": "1140px", "$type": "dimension" },
    "container-gutter": { "$value": "24px",   "$type": "dimension" },
    "breakpoint-mobile":{ "$value": "560px",  "$type": "dimension" },
    "breakpoint-tablet":{ "$value": "900px",  "$type": "dimension" }
  },
  "radius": {
    "xs":   { "$value": "2px",  "$type": "dimension" },
    "sm":   { "$value": "3px",  "$type": "dimension" },
    "md":   { "$value": "6px",  "$type": "dimension" },
    "lg":   { "$value": "8px",  "$type": "dimension" },
    "xl":   { "$value": "12px", "$type": "dimension" },
    "2xl":  { "$value": "16px", "$type": "dimension" },
    "pill": { "$value": "40px", "$type": "dimension" }
  },
  "shadow": {
    "sm":   { "$value": "0 1px 0 rgba(24,54,51,0.04)", "$type": "shadow" },
    "card": { "$value": "0 1px 0 rgba(24,54,51,0.04), 0 20px 42px -26px rgba(12,59,56,0.30)", "$type": "shadow" },
    "pop":  { "$value": "0 30px 60px -30px rgba(12,59,56,0.40)", "$type": "shadow" },
    "btn":  { "$value": "0 12px 26px -12px rgba(18,181,171,0.85)", "$type": "shadow" }
  },
  "motion": {
    "ease-standard": { "$value": "cubic-bezier(0.2,0.6,0.2,1)", "$type": "cubicBezier" },
    "duration-fast": { "$value": "180ms", "$type": "duration" },
    "duration-mid":  { "$value": "250ms", "$type": "duration" },
    "duration-slow": { "$value": "400ms", "$type": "duration" }
  }
}
