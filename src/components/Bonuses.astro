---
import Section from './ui/Section.astro';
import SectionLabel from './ui/SectionLabel.astro';
import Badge from './ui/Badge.astro';

const bonuses = [
  {
    tier: 'Ступень 1',
    title: 'Стартовый комплект нутрициолога',
    text: 'Готовые анкеты клиента, дневники питания и симптомов, шаблоны рекомендаций и отчётов, чек-листы консультаций, согласие на обработку данных.',
    icon: `<path d="M4 8h16v4H4zM5 12h14v9H5zM12 8v13M12 8s-1-4-4-4-2 4 4 4zM12 8s1-4 4-4 2 4-4 4z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>`,
  },
  {
    tier: 'Ступень 1',
    title: 'Атлас решений нутрициолога',
    text: 'Схемы «жалоба → вопросы → механизмы → приоритет → красные флаги → границы компетенции» по 20–30 частым запросам.',
    icon: `<path d="M6 3h9l3 3v15H6zM15 3v3h3M9 12h6M9 16h6" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>`,
  },
  {
    tier: 'Ступень 1',
    title: 'Библиотека консультаций PRO',
    text: 'Записи сложных реальных разборов с картой наблюдения: где сильные вопросы и где принималось ключевое решение.',
    icon: `<path d="M5 4h14v16l-7-3-7 3V4z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>`,
  },
  {
    tier: 'Ступень 2',
    title: 'Супервизионный пакет PRO',
    text: 'Отдельные групповые супервизии строго по разбору клиентов учеников — глубокая работа над вашими кейсами.',
    icon: `<circle cx="9" cy="8" r="3" stroke="currentColor" stroke-width="1.4"/><circle cx="16" cy="10" r="2.4" stroke="currentColor" stroke-width="1.4"/><path d="M3 20c0-3 2.7-5 6-5s6 2 6 5M14 20c0-2 1-3.5 3-3.5s4 1.2 4 3.5" stroke="currentColor" stroke-width="1.4"/>`,
  },
  {
    tier: 'Ступень 2',
    title: 'Библиотека сложных случаев',
    text: 'Архив с навигацией: метаболический синдром, сложные эндокринные паттерны, лекарственные взаимодействия, кейс «всё нарушено — с чего начать».',
    icon: `<path d="M4 5h16v14H4zM4 9h16M8 13h8M8 16h5" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>`,
  },
  {
    tier: 'Ступень 2',
    title: 'Модуль «Продвижение в Telegram»',
    text: 'Как создать и вести экспертный канал, который продаёт и привлекает клиентов, и копирайтинг, который влюбляет.',
    icon: `<path d="M21 4L3 11l6 2 2 6 3-4 4 3 3-14z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/>`,
  },
];
---

<Section bg="paper">
  <div class="rv mb-12 max-w-[760px]">
    <SectionLabel>Бонусы участникам</SectionLabel>
    <h2 class="text-h2 font-semibold text-ink">Готовый инструментарий, чтобы начать работать сразу</h2>
  </div>

  <div class="stagger-grid grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    {
      bonuses.map((b) => (
        <article class="card-hover rounded-card border border-line bg-surface p-7 shadow-card">
          <span class="mb-5 grid h-12 w-12 place-items-center rounded-card bg-accent-wash text-accent-strong">
            <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6">
              <Fragment set:html={b.icon} />
            </svg>
          </span>
          <Badge variant="tier">{b.tier}</Badge>
          <h3 class="mt-3.5 text-h4 font-semibold text-ink">{b.title}</h3>
          <p class="mt-2.5 text-small text-muted">{b.text}</p>
        </article>
      ))
    }
  </div>
</Section>
