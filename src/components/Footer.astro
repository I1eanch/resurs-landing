---
/**
 * Не Section: у подвала свой ритм и свой контейнер.
 * Класс `deep` — маркер тёмного контекста, за него цепляется `.deep .ph`.
 */
const base = import.meta.env.BASE_URL;
const oferta = `${base}oferta`.replace('//', '/');
const politika = `${base}politika`.replace('//', '/');

const links = [
  { href: '#program', label: 'Программа' },
  { href: '#price', label: 'Тарифы' },
  { href: '#experts', label: 'Эксперты' },
  { href: '#cases', label: 'Отзывы' },
];
---

<footer class="deep bg-deep-3 text-on-deep-muted">
  <div class="mx-auto max-w-[1140px] px-6 py-16">
    <div class="grid gap-10 md:grid-cols-[1fr_auto] md:items-start">
      <div>
        <a
          href="#top"
          class="inline-flex items-center gap-3 font-display text-[19px] font-semibold text-on-deep no-underline"
        >
          <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-accent text-on-accent">
            <svg viewBox="0 0 24 24" fill="none" class="h-5 w-5" aria-hidden="true">
              <path d="M12 3c3.5 2 6 5 6 9a6 6 0 1 1-12 0c0-4 2.5-7 6-9z" stroke="currentColor" stroke-width="1.6"
              ></path>
            </svg>
          </span>
          Школа нутрициологов «Ресурс»
        </a>
        <p class="mt-3 max-w-[36ch] text-small">
          Онлайн-школа здоровья и профессии нутрициолога. Системный подход к восстановлению организма.
        </p>
      </div>

      <nav class="flex flex-wrap gap-x-7 gap-y-3">
        {
          links.map((l) => (
            <a
              href={l.href}
              class="text-small text-on-deep-muted no-underline transition-colors duration-200 ease-standard hover:text-on-deep"
            >
              {l.label}
            </a>
          ))
        }
        <a
          href="#"
          class="text-small text-on-deep-muted no-underline transition-colors duration-200 ease-standard hover:text-on-deep"
        >
          <span class="ph">[Telegram]</span>
        </a>
      </nav>
    </div>
  </div>

  <div class="border-t border-deep-line">
    <div class="mx-auto max-w-[1140px] px-6 py-8 text-small leading-body">
      ИП Кобляков Артем Анатольевич · ИНН 246517375248 · ОГРНИП 324237500314271 · Краснодар · тел. +7 (923) 321-69-21 ·
      artem@ellachoco.ru<br />
      <a
        href={oferta}
        class="text-on-deep-muted underline underline-offset-2 transition-colors duration-200 ease-standard hover:text-on-deep"
        >Оферта</a
      > · <a
        href={politika}
        class="text-on-deep-muted underline underline-offset-2 transition-colors duration-200 ease-standard hover:text-on-deep"
        >Политика обработки персональных данных</a
      > · <span class="ph">[ Согласие на обработку ]</span> · © 2026 Школа нутрициологов «Ресурс»
    </div>
  </div>
</footer>
