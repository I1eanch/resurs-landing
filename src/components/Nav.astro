---
import Button from './ui/Button.astro';

const links = [
  { href: '#who', label: 'Нутрициолог', mobileLabel: 'Кто такой нутрициолог' },
  { href: '#program', label: 'Программа', mobileLabel: 'Программа' },
  { href: '#cases', label: 'Отзывы', mobileLabel: 'Отзывы' },
  { href: '#experts', label: 'Эксперты', mobileLabel: 'Эксперты' },
  { href: '#price', label: 'Тарифы', mobileLabel: 'Тарифы' },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-line bg-paper/85 backdrop-blur-[10px]">
  <div class="mx-auto flex h-[66px] max-w-[var(--container-max)] items-center justify-between px-6">
    <a href="#top" class="flex items-center gap-2.5 font-body text-[15px] font-semibold text-ink no-underline">
      <span class="grid h-8 w-8 shrink-0 place-items-center rounded-full bg-accent text-on-accent" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" class="h-[18px] w-[18px]">
          <path d="M12 3c3.5 2 6 5 6 9a6 6 0 1 1-12 0c0-4 2.5-7 6-9z" stroke="currentColor" stroke-width="1.6" />
          <path d="M12 9v8M12 12l2.5-2M12 14l-2.5-2" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
        </svg>
      </span>
      <span class="max-sm:hidden">Школа нутрициологов «Ресурс»</span>
      <span class="sm:hidden">«Ресурс»</span>
    </a>

    <nav class="hidden items-center gap-7 min-[901px]:flex" aria-label="Основная навигация">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="font-body text-[15px] text-muted no-underline transition-colors duration-200 hover:text-accent-strong"
          >
            {l.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden min-[901px]:block">
      <Button href="#price" size="sm">Записаться</Button>
    </div>

    <button
      id="burger"
      class="flex h-10 w-10 flex-col items-center justify-center gap-[5px] rounded-btn min-[901px]:hidden"
      aria-label="Меню"
      aria-expanded="false"
      aria-controls="mobileMenu"
    >
      <span class="block h-[2px] w-[22px] rounded bg-ink"></span>
      <span class="block h-[2px] w-[22px] rounded bg-ink"></span>
      <span class="block h-[2px] w-[22px] rounded bg-ink"></span>
    </button>
  </div>

  <div
    id="mobileMenu"
    class="mobile-menu absolute inset-x-0 top-[66px] flex flex-col gap-1 border-b border-line bg-paper p-6 shadow-card min-[901px]:hidden"
  >
    {
      links.map((l) => (
        <a href={l.href} class="rounded-card px-2 py-3 font-body text-[17px] text-ink no-underline hover:bg-surface-alt">
          {l.mobileLabel}
        </a>
      ))
    }
    <Button href="#price" fullWidth class="mt-3">Записаться в 6 поток</Button>
  </div>
</header>
