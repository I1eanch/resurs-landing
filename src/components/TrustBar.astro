---
/**
 * Полоса доверия. Счётчик анимирует только цифру — знак «+»
 * вынесен в отдельный span, иначе data-count перезапишет его.
 */
import { stats } from '../data/site';

const items = [
  { count: stats.students, label: 'учеников школы' },
  { count: stats.restored, label: 'восстановили здоровье с Мариной лично' },
  { count: stats.practitioners, label: 'практикующих нутрициологов' },
];
---

<div class="border-b border-line bg-surface-alt">
  <div
    class="mx-auto flex max-w-[var(--container-max)] flex-col gap-9 px-6 py-11 lg:flex-row lg:items-center lg:justify-between lg:gap-14"
  >
    <p class="flex items-center gap-3.5 font-display text-h4 font-semibold text-ink">
      <span class="grid h-11 w-11 shrink-0 place-items-center rounded-card bg-accent-wash text-accent-strong">
        <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
          <path d="M12 2l7 3v6c0 5-3 8-7 9-4-1-7-4-7-9V5l7-3z" stroke="currentColor" stroke-width="1.5"></path>
          <path
            d="M8.5 12l2.5 2.5L16 9.5"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
      </span>
      Под руководством Марины Жигульской
    </p>

    <div class="stagger-grid grid gap-8 sm:grid-cols-3 lg:gap-12">
      {
        items.map((s) => (
          <div class="border-t border-line-strong pt-4 sm:border-t-0 sm:border-l sm:pt-0 sm:pl-5">
            {/* Между <b> и «+» не должно быть переноса строки: он отрендерится
                пробелом, и получится «3000 +» вместо «3000+». */}
            <p class="font-display text-[28px] font-semibold leading-none text-deep">
              <b class="[font-weight:inherit]" data-count={s.count}>0</b><span>+</span>
            </p>
            <span class="mt-2 block text-small text-muted">{s.label}</span>
          </div>
        ))
      }
    </div>
  </div>
</div>
