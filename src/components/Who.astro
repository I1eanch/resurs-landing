---
import Section from './ui/Section.astro';
import SectionLabel from './ui/SectionLabel.astro';

const pillars = [
  {
    role: '01 · Специалист',
    title: 'Разбирается в организме',
    text: 'Понимает процессы в теле, нутрициологию и натуропатию. Видит организм как систему и находит причину, а не гасит симптом.',
    icon: `<path d="M9 3v5.5a4.5 4.5 0 11-3 4.2M15 3v5.5a4.5 4.5 0 103 4.2" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/><path d="M9 3h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>`,
  },
  {
    role: '02 · Наставник',
    title: 'Учит и объясняет',
    text: 'Передаёт клиенту знания и привычки, объясняет простым языком и формирует новое отношение к здоровью, а не просто выдаёт схему.',
    icon: `<path d="M4 6l8-3 8 3-8 3-8-3zM8 8v5c0 1.7 1.8 3 4 3s4-1.3 4-3V8" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>`,
  },
  {
    role: '03 · Коуч',
    title: 'Доводит до результата',
    text: 'Понимает психологию и нейропсихологию, умеет поддержать и удержать клиента в процессе — и довести его до реального результата.',
    icon: `<path d="M12 21s-7-4.5-7-10a7 7 0 0114 0c0 5.5-7 10-7 10z" stroke="currentColor" stroke-width="1.5"/><circle cx="12" cy="11" r="2.4" stroke="currentColor" stroke-width="1.5"/>`,
  },
];
---

<Section id="who" bg="paper">
  <div class="rv mb-12 max-w-[760px]">
    <SectionLabel>Кто такой нутрициолог</SectionLabel>
    <h2 class="text-h2 font-semibold text-ink">Настоящий нутрициолог — это три роли в одном человеке</h2>
    <p class="mt-4 text-lead text-muted">
      Это не «человек с меню». Чтобы приводить людей к результату, нутрициолог соединяет в себе специалиста, наставника
      и коуча — и мы развиваем все три роли.
    </p>
  </div>

  <div class="stagger-grid grid gap-6 md:grid-cols-3">
    {
      pillars.map((p) => (
        <article class="card-hover relative overflow-hidden rounded-card border border-line bg-surface p-7 pt-9 shadow-card">
          <span class="absolute inset-x-0 top-0 h-1 bg-accent" aria-hidden="true" />
          <span class="day-marker mb-5 grid h-12 w-12 place-items-center rounded-full bg-accent-wash text-accent-strong">
            <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6">
              <Fragment set:html={p.icon} />
            </svg>
          </span>
          <div class="text-eyebrow font-semibold uppercase tracking-eyebrow text-accent-strong">{p.role}</div>
          <h3 class="mt-3 text-h4 font-semibold text-ink">{p.title}</h3>
          <p class="mt-2.5 text-small text-muted">{p.text}</p>
        </article>
      ))
    }
  </div>

  <p class="rv mx-auto mt-12 max-w-[720px] text-center font-display text-[19px] italic leading-body text-muted">
    Именно поэтому одного меню недостаточно. Мы учим работать со всеми тремя ролями сразу.
  </p>
</Section>
