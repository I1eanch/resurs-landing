---
import Section from './ui/Section.astro';
import SectionLabel from './ui/SectionLabel.astro';

const points = [
  {
    title: 'Рынок полон «специалистов по добавкам»',
    text: 'Многие работают только с симптомом: «вот тебе добавка» — или выдают всем одно и то же меню. Настоящей работой с организмом это назвать сложно.',
    icon: 'warning',
  },
  {
    title: 'К сильному нутрициологу — очередь',
    text: 'К нашим практикующим выпускникам не записаться на месяц вперёд. На тех, кто умеет думать и вести до результата, спрос только растёт.',
    icon: 'people',
  },
  {
    title: 'Люди устали от «волшебной таблетки»',
    text: 'Запрос сместился к первопричине, питанию и образу жизни. Это ровно то поле, где работает системный нутрициолог.',
    icon: 'focus',
  },
  {
    title: 'Это творческая профессия',
    text: 'Здесь выигрывает мышление, а не километровые схемы. Работа онлайн, из любой точки, без потолка по доходу.',
    icon: 'star',
  },
];
---

<Section id="why-now" bg="tint">
  <div class="rv mb-12 max-w-[860px]">
    <SectionLabel>Почему именно сейчас</SectionLabel>
    <h2 class="text-h2 font-semibold text-ink">Нутрициологов много. Тех, кто умеет думать, — единицы</h2>
    <p class="mt-4 text-lead text-muted">
      Да, школ и нутрициологов сейчас хватает. Но большинство работает по схеме «симптом → добавка» или сажает всех на
      одинаковые протоколы. Настоящих системных специалистов, которые видят организм целиком, по-прежнему мало — и спрос
      именно на них только растёт.
    </p>
  </div>

  <div class="stagger-grid grid gap-6 md:grid-cols-2">
    {
      points.map((p) => (
        <article class="card-hover flex gap-5 rounded-card border border-line bg-surface p-7 shadow-card">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-card bg-accent-wash text-accent-strong">
            {p.icon === 'warning' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
                <path d="M12 3l9 16H3l9-16z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                <path d="M12 10v4M12 17h.01" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
              </svg>
            )}
            {p.icon === 'people' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
                <path
                  d="M8 12a3 3 0 100-6 3 3 0 000 6zM16 12a3 3 0 100-6 3 3 0 000 6zM2 20c0-2.8 2.7-4 6-4M22 20c0-2.8-2.7-4-6-4"
                  stroke="currentColor"
                  stroke-width="1.5"
                />
              </svg>
            )}
            {p.icon === 'focus' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
                <path d="M12 3v4M12 21v-4M3 12h4M21 12h-4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
                <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.6" />
              </svg>
            )}
            {p.icon === 'star' && (
              <svg viewBox="0 0 24 24" fill="none" class="h-6 w-6" aria-hidden="true">
                <path
                  d="M12 2l2.5 5 5.5.8-4 3.9.9 5.5L12 19l-4.9 2.6.9-5.5-4-3.9 5.5-.8L12 2z"
                  stroke="currentColor"
                  stroke-width="1.4"
                  stroke-linejoin="round"
                />
              </svg>
            )}
          </span>
          <div>
            <h3 class="text-h4 font-semibold text-ink">{p.title}</h3>
            <p class="mt-2.5 text-small text-muted">{p.text}</p>
          </div>
        </article>
      ))
    }
  </div>
</Section>
