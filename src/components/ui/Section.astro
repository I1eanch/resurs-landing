---
/**
 * Скелет секции. Задаёт вертикальный ритм и ширину контейнера —
 * значения не меняются нигде на странице.
 *
 * Фоны чередуются по паттерну paper → tint → paper с точечными
 * тёмными вставками. Три одинаковых подряд — уже плоско.
 */
interface Props {
  id?: string;
  bg?: 'paper' | 'tint' | 'deep' | 'final';
  class?: string;
  containerClass?: string;
}

const { id, bg = 'paper', class: className = '', containerClass = '' } = Astro.props;

const backgrounds: Record<string, string> = {
  paper: 'bg-paper',
  tint: 'bg-surface-alt',
  deep: 'deep bg-deep text-on-deep',
  final: 'final bg-deep-3 text-on-deep',
};
---

<section
  id={id}
  class:list={['relative overflow-hidden py-[var(--section-y)]', backgrounds[bg], className]}
>
  <slot name="backdrop" />
  <div class:list={['relative z-10 mx-auto max-w-[1140px] px-6', containerClass]}>
    <slot />
  </div>
</section>
