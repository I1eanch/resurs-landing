---
import Layout from '../layouts/Layout.astro';
import Button from '../components/ui/Button.astro';
import { withBase } from '../lib/url';
---

<Layout
  title="Страница не найдена — Школа нутрициологов «Ресурс»"
  description="Такой страницы нет. Вернитесь на главную."
>
  <main class="mx-auto flex min-h-dvh max-w-[640px] flex-col items-center justify-center px-6 py-24 text-center">
    <p class="font-display text-[clamp(64px,14vw,120px)] font-semibold leading-none text-accent">404</p>

    <h1 class="mt-6 text-h2 font-semibold text-ink">Такой страницы нет</h1>

    <p class="mt-4 text-lead text-muted">
      Возможно, ссылка устарела или в адресе опечатка. Набор в 6 поток идёт на главной.
    </p>

    <div class="mt-10 flex flex-wrap justify-center gap-3.5">
      <Button href={withBase('')} size="lg">На главную</Button>
      <Button href={`${withBase('')}#price`} variant="line" size="lg">Смотреть тарифы</Button>
    </div>
  </main>
</Layout>
